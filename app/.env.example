# ===============================================================
# Expo アプリ用 環境変数サンプル
# 使い方: このファイルを .env にコピーし、値を埋めてください。
# .env はコミットしない（.gitignore 済み）
# ===============================================================

# ---- Firebase Web SDK 設定 ----
# Firebase コンソール → プロジェクト設定 → 「マイアプリ」→ Web アプリ の設定値
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ---- Google OAuth クライアント ID ----
# Google Cloud Console → APIs & Services → Credentials
# 3種類すべて作成が必要:
#   - Web アプリケーション（Firebase Auth の Google プロバイダ用）
#   - iOS（バンドル ID: com.makxas.salesrecording）
#   - Android（パッケージ名: com.makxas.salesrecording + 開発/本番の SHA-1）
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# ---- EAS Project ID (EAS ビルドを使う場合のみ) ----
# `eas init` 実行後に自動的に設定される
EAS_PROJECT_ID=
