{
  "name": "sales-recording-app",
  "private": true,
  "version": "0.1.0",
  "description": "出張買取営業向け 録音・文字起こし・議事録生成アプリ",
  "workspaces": [
    "app",
    "functions"
  ],
  "scripts": {
    "app": "npm run start --workspace app",
